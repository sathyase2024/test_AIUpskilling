# SkillForge — Production Environment Variables
# Copy this to .env on your VPS: cp .env.production.example .env
# Then fill in real values. NEVER commit .env to git.

# ── Database ──────────────────────────────────────────────────────────────────
# Strong random password — generate with: openssl rand -base64 32
DB_PASSWORD=change_this_to_a_strong_random_password

# ── Authentication ────────────────────────────────────────────────────────────
# Long random string — generate with: openssl rand -base64 48
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# ── Domain ───────────────────────────────────────────────────────────────────
# Your domain pointing to this VPS (used for CORS and SSL)
DOMAIN=yourdomain.com

# ── AI / Lesson Generation (optional) ────────────────────────────────────────
# Leave blank to disable AI lesson generation (app still works with seeded content)
ANTHROPIC_API_KEY=
